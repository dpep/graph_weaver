#!/usr/bin/env ruby
# regenerate lib/generated/ from queries/

require "fileutils"
require_relative "../lib/schema"
require_relative "../lib/struct_codegen"

root = File.expand_path("..", __dir__)
FileUtils.mkdir_p(File.join(root, "lib/generated"))

Dir[File.join(root, "queries/*.graphql")].sort.each do |query_path|
  base = File.basename(query_path, ".graphql")
  module_name = "#{ActiveSupport::Inflector.camelize(base)}Query"

  source = StructCodegen.new(
    schema: Demo::Schema,
    executor_const: "Demo::Schema",
    query: File.read(query_path),
    module_name:,
  ).generate

  path = File.join(root, "lib/generated/#{base}_query.rb")
  File.write(path, source)
  puts "wrote #{path}"
end
