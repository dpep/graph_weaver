#!/usr/bin/env ruby
# regenerate lib/generated/ from queries/

require_relative "../lib/schema"
require_relative "../lib/struct_codegen"

root = File.expand_path("..", __dir__)
query = File.read(File.join(root, "queries/person.graphql"))

source = StructCodegen.new(
  schema: Demo::Schema,
  schema_const: "Demo::Schema",
  query:,
  module_name: "PersonQuery",
).generate

path = File.join(root, "lib/generated/person_query.rb")
Dir.mkdir(File.dirname(path)) unless Dir.exist?(File.dirname(path))
File.write(path, source)
puts "wrote #{path}"
