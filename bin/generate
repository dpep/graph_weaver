#!/usr/bin/env ruby
# regenerate spec/generated/ from spec/queries/

require_relative "../lib/graph_weaver"
require_relative "../spec/support/schema"

root = File.expand_path("..", __dir__)
GraphWeaver.generate!(
  schema: Demo::Schema,
  queries: File.join(root, "spec/queries"),
  output: File.join(root, "spec/generated"),
  executor: Demo::Schema,
).each { |path| puts "wrote #{path}" }
